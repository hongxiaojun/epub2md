{
  "name": "ebook-chapter-splitter",
  "version": "1.0.0",
  "description": "Split PDF and EPUB ebooks into individual chapter markdown files",
  "author": "add",
  "mode": "Production",
  "dependencies": {
    "python": ">=3.8",
    "libraries": [
      "PyPDF2>=3.0.0",
      "ebooklib>=0.18",
      "html2text>=2020.0.0"
    ]
  },
  "trigger_phrases": [
    "拆解电子书",
    "split ebook into chapters",
    "把PDF转换成章节markdown",
    "电子书章节拆分",
    "convert ebook to markdown chapters"
  ],
  "exclusions": [
    "scanned PDFs without OCR",
    "DRM-protected files",
    "audio/video content",
    "complex table layouts"
  ],
  "boundary": {
    "in_scope": [
      "PDF and EPUB format ebooks",
      "text-based content extraction",
      "Chinese and English content",
      "standard chapter formats"
    ],
    "out_of_scope": [
      "scanned/image-only PDFs",
      "DRM-protected files",
      "audio/video content",
      "complex layouts with tables"
    ]
  },
  "gates": [
    "validate_input",
    "check_dependencies",
    "confirm_output"
  ],
  "outputs": {
    "markdown_files": {
      "format": "书名-第N章节-标题.md",
      "encoding": "utf-8",
      "structure": "# Chapter Title\n\nContent"
    }
  },
  "usage": {
    "cli": "python scripts/split_ebook.py --input <dir> --output <dir>",
    "skill": "/ebook-chapter-splitter"
  }
}
